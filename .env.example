# Immobilien Akademie Smart — Umgebungsvariablen
# Kopiere diese Datei zu .env und trage echte Werte lokal oder in Railway ein.
# Keine echten Secrets ins Repository committen.

# ─── Runtime / App ───────────────────────────────────
# production auf Railway, development lokal.
NODE_ENV=development
# Railway setzt PORT automatisch. Lokal nutzt der Server sonst 8080.
PORT=8080
# Öffentliche Basis-URL für Redirects, E-Mails, Sitemap und HealthWatcher.
APP_URL=https://immobilien-akademie-smart.de
# Optionaler Alias für Trial-Follow-up/Monitoring, falls abweichend von APP_URL.
PUBLIC_URL=https://immobilien-akademie-smart.de
# Optional: detailliertere Serverlogs.
LOG_LEVEL=info

# ─── Datenbank ───────────────────────────────────────
# MySQL Connection String für Drizzle, Migrationen, Auth, Lernfortschritt, Stripe-Freischaltung.
DATABASE_URL=mysql://user:password@host:3306/database

# ─── Auth / Sessions ─────────────────────────────────
# Pflicht: HS256-JWT-Secret für app_session_id. Beispiel generieren:
# openssl rand -base64 32
JWT_SECRET=<generate-with-openssl-rand-base64-32>
# Optional: Manus/OAuth-Server; lokale E-Mail/Passwort-Auth funktioniert ohne diese Werte.
OAUTH_SERVER_URL=
VITE_APP_ID=
# Optionaler OAuth/Forge Owner-Fallback aus älteren Integrationen.
OWNER_OPEN_ID=

# ─── Magic / Owner / Inspect ─────────────────────────
# Optionaler Magic-Link-Zugang; nur mit starkem Secret aktivieren.
MAGIC_LINK_SECRET=<generate-with-openssl-rand-base64-32>
# Owner-E-Mail für Owner-2FA, Alerts und Owner-Tools.
OWNER_EMAIL=owner@example.com
# Owner-Zugangscode. Nach jeder Sichtbarkeit in Chat/Screenshot/Logs rotieren.
OWNER_MAGIC_CODE=<random-32-char-string>
# Owner-2FA-Modus: email | totp | both | none. Produktion sollte nicht none verwenden.
OWNER_2FA_METHOD=totp
# Base32-Secret aus dem TOTP-Setup; nur setzen, wenn OWNER_2FA_METHOD totp/both nutzt.
OWNER_TOTP_SECRET=<base32-from-speakeasy>
# Signiert Inspect-Links. In Produktion Pflicht für Inspect-Modus.
INSPECT_JWT_SECRET=<generate-with-openssl-rand-base64-32>

# ─── KI-Provider ─────────────────────────────────────
# Anthropic: RAG-Tutor, Rechenpraxis-Assistent, Fallstudien/Kursbuch/Agent-Funktionen.
ANTHROPIC_API_KEY=sk-ant-...
# Google Gemini: RAG-/LLM-Fallbacks und Agent-Funktionen.
GEMINI_API_KEY=...
# Legacy/alternative Gemini-Variable, von SuperAgent als Fallback geprüft.
GOOGLE_AI_API_KEY=
# Groq: schnelle Fallback-Antworten und Transkription.
GROQ_API_KEY=gsk_...
# Optional: OpenAI-kompatibler LLM-Pfad in server/_core/llm.ts.
OPENAI_API_KEY=
# ElevenLabs: TTS/Audio-Proxy.
ELEVENLABS_API_KEY=

# ─── Stripe / Zahlungen ──────────────────────────────
# Testmodus: sk_test_/pk_test_; Live erst nach fachlicher und rechtlicher Freigabe.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Frontend-Public-Key. Der Code nutzt je nach Seite VITE_STRIPE_PUBLIC_KEY oder STRIPE_PUBLISHABLE_KEY.
VITE_STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Partner-Auszahlungen via Stripe Connect Express (nach Dashboard-Aktivierung)
STRIPE_CONNECT_ENABLED=false
# Automatische Quartals-Ledger-Generierung (1. Jan/Apr/Jul/Okt, 02:00 NightCron)
PARTNER_PAYOUT_CRON_ENABLED=false
# Optionale feste Price-IDs aus Stripe Dashboard (empfohlen für Live)
STRIPE_PRICE_RECHENPRAXIS_MONTHLY=price_...
STRIPE_PRICE_VERWALTER_TOOLS_MONTHLY=price_...
# Verwalter Tools: 1 = Paid-Zwang (vt-Sentinel), 0/leer = Beta gratis für alle Login-Nutzer
VERWALTER_TOOLS_GATING=0
# Verwalter-Automatisierung (Phase P2+ — Default aus)
VERWALTER_INBOX_ENABLED=0
VERWALTER_VOICE_ENABLED=0
VERWALTER_BELEG_OCR_ENABLED=0
STRIPE_PRICE_RENEWAL_MONTHLY=price_...
STRIPE_PRICE_RENEWAL_YEARLY=price_...
STRIPE_PRICE_COMPLIANCE_YEARLY=price_...
STRIPE_PRICE_B2B_STARTER=price_...
STRIPE_PRICE_B2B_PROFESSIONAL=price_...
# Module & Bundles (Einmalzahlung, optional — 12 Price-IDs für Live)
STRIPE_PRICE_MODUL_1=price_...
STRIPE_PRICE_MODUL_2=price_...
STRIPE_PRICE_MODUL_3=price_...
STRIPE_PRICE_MODUL_4=price_...
STRIPE_PRICE_MODUL_5=price_...
STRIPE_PRICE_MODUL_KOMPLETT=price_...
STRIPE_PRICE_BUNDLE_STARTER=price_...
STRIPE_PRICE_BUNDLE_VERWALTER=price_...
STRIPE_PRICE_BUNDLE_MAKLER_PLUS=price_...
STRIPE_PRICE_BUNDLE_PROFI=price_...
STRIPE_PRICE_BUNDLE_GUTACHTER=price_...
STRIPE_PRICE_BUNDLE_KOMPLETT=price_...

# ─── E-Mail / Resend ─────────────────────────────────
# Resend wird für Registrierung, Passwort-Reset, Kauf, OTP/2FA, Trial-Follow-up und Alerts genutzt.
RESEND_API_KEY=re_...
# Legacy/optional: wird nur noch als optionale Variable gewarnt, nicht als primärer Mailer genutzt.
GMAIL_USER=

# ─── Monitoring / Analytics ──────────────────────────
# Sentry Server und Client.
SENTRY_DSN=https://example@o000000.ingest.sentry.io/000000
VITE_SENTRY_DSN=https://example@o000000.ingest.sentry.io/000000
# Google Analytics Hook erwartet window.gtag; tatsächliches Script/Consent separat konfigurieren.
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Google / Maps / OAuth Frontend ──────────────────
# Optionaler Google OAuth Client für client/src/lib/oauth.ts.
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# Optionaler Forge/Maps-Proxy im Frontend.
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=

# ─── Forge / Manus Storage Runtime ───────────────────
# Wenn gesetzt, nutzt server/storage.ts Forge/Manus Storage statt lokaler .data/uploads.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── Lokale/E2E-Testvariablen ────────────────────────
# Nur für Playwright/E2E-Tests; keine Produktions-Credentials verwenden.
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=<test-password>
# CI optional: Repository Variable STRIPE_E2E_ENABLED=true + Secret MAGIC_LINK_SECRET
# für Live-Checkout-Tests in .github/workflows/ci.yml (Job e2e-stripe)

# ─── Backup-Workflow-Secrets (nur GitHub Secrets) ────
# Diese Werte NICHT in .env lokal brauchen, außer du testest den Beispielworkflow manuell.
# RAILWAY_TOKEN=***
# RAILWAY_PROJECT_ID=***
# RAILWAY_ENVIRONMENT=production
# R2_ACCOUNT_ID=***
# R2_ACCESS_KEY_ID=***
# R2_SECRET_ACCESS_KEY=***
# R2_BUCKET=***
# R2_PREFIX=mysql/production
# BACKUP_ENCRYPTION_PASSPHRASE=***
