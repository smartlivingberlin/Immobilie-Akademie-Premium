# ============================================================
# MaklerLern.de – Umgebungsvariablen
# ============================================================
# Kopiere diese Datei nach ".env" und fülle die Werte aus.
# Felder mit [PFLICHT] müssen gesetzt werden.
# Felder mit [OPTIONAL] können leer bleiben.
# ============================================================

# ── Basis-Konfiguration [PFLICHT] ───────────────────────────

# Geheimnis für JWT-Session-Tokens (mind. 32 zufällige Zeichen)
# Generieren: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=BITTE_AENDERN_32_ZEICHEN_ZUFAELLIG

# Server-Port (Standard: 3000)
PORT=3000

# Umgebung
NODE_ENV=production

# ── Datenbank [PFLICHT] ─────────────────────────────────────

# Option A: TiDB Cloud (Manus-Standard)
# Format: mysql://USER:PASSWORT@HOST:4000/DATENBANKNAME?ssl={"rejectUnauthorized":true}
# DATABASE_URL=mysql://root:PASSWORT@gateway02.us-east-1.prod.aws.tidbcloud.com:4000/maklerlearn

# Option B: PlanetScale (kostenlos, MySQL-kompatibel)
# DATABASE_URL=mysql://USER:PASSWORT@aws.connect.psdb.cloud/DATENBANKNAME?ssl={"rejectUnauthorized":true}

# Option C: Railway (kostenlos bis 500MB)
# DATABASE_URL=mysql://root:PASSWORT@containers-us-west-1.railway.app:PORT/railway

# Option D: Lokales MySQL (Entwicklung)
# DATABASE_URL=mysql://root:root@localhost:3306/maklerlearn

DATABASE_URL=mysql://user:passwort@host:3306/maklerlearn

# ── Erster Admin-Nutzer ─────────────────────────────────────
# Der erste registrierte Nutzer wird automatisch Admin.
# Dieser Wert ist nur ein Hinweis – kein technischer Effekt.
OWNER_OPEN_ID=local:admin@deinedomain.de

# ── KI-Assistent [OPTIONAL] ────────────────────────────────
# Das Portal funktioniert OHNE KI. KI nur für den Chat-Assistenten.

# Option A: OpenAI (empfohlen, GPT-4o-mini sehr günstig ~0.15$/1M Tokens)
# OPENAI_API_KEY=sk-...

# Option B: Anthropic Claude (Alternative)
# ANTHROPIC_API_KEY=sk-ant-...

# Option C: Manus Forge (nur auf Manus)
# BUILT_IN_FORGE_API_URL=https://forge.manus.im
# BUILT_IN_FORGE_API_KEY=...

# ── Manus OAuth [NUR FÜR MANUS] ────────────────────────────
# Leer lassen → automatisch lokales Email/Passwort-Login
# Nur ausfüllen wenn auf Manus deployed

# OAUTH_SERVER_URL=
# VITE_APP_ID=
# VITE_OAUTH_PORTAL_URL=

# ── App-ID (Manus-intern, sonst ignoriert) ──────────────────
VITE_APP_ID=maklerlearn-local
