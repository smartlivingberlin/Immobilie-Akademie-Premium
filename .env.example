# Immobilien Akademie Smart — Umgebungsvariablen
# Kopiere diese Datei zu .env und trage die echten Werte ein

# ─── DATENBANK ───────────────────────────────────────
DATABASE_URL=mysql://user:password@host:port/database

# ─── AUTH ────────────────────────────────────────────
JWT_SECRET=dein-geheimer-jwt-schluessel-min-32-zeichen

# ─── KI-MODELLE ──────────────────────────────────────
GEMINI_API_KEY=dein-gemini-api-key
ANTHROPIC_API_KEY=dein-anthropic-api-key

# ─── STRIPE (Zahlungen) ──────────────────────────────
STRIPE_SECRET_KEY=sk_test_...        # sk_live_... für Produktion
STRIPE_WEBHOOK_SECRET=whsec_...
VITE_STRIPE_PUBLIC_KEY=pk_test_...   # pk_live_... für Produktion

# ─── E-MAIL ──────────────────────────────────────────
GMAIL_USER=deine@gmail.com
GMAIL_PASSWORD=dein-app-passwort
# Optional: Resend (nach Domain-Kauf)
# RESEND_API_KEY=re_...

# ─── SENTRY (Error Monitoring) ───────────────────────
# Einrichten: sentry.io → Neues Projekt → DSN kopieren
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# ─── OAUTH (Google Login) ────────────────────────────
# Einrichten: console.cloud.google.com
# → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# ─── ADMIN ───────────────────────────────────────────
ADMIN_PASSWORD=starkes-passwort-min-16-zeichen
OWNER_MAGIC_CODE=OWNER-xxx

# ─── AUDIO/VOICE ─────────────────────────────────────
# Optional: ElevenLabs für hochwertige Stimme
GROQ_API_KEY=dein-groq-key

# ─── ANALYTICS ──────────────────────────────────────────────
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
